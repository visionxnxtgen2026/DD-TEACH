# 🌐 SERVER CONFIGURATION
PORT=5000
NODE_ENV=development

# 🗄️ DATABASE (Unified DB Name)
# Make sure your local MongoDB is running!
MONGO_URI=mongodb://127.0.0.1:27017/dd_teach

# 🔐 SECURITY & AUTHENTICATION
# Change this 'super_secret' to something very long and random in production
JWT_SECRET=your_super_secret_key_12345_dd_teach_2026
JWT_EXPIRE=7d

# 🌍 FRONTEND URL (CORS)
# This allows your Vite + React app to talk to this backend
CLIENT_URL=http://localhost:5173

# 📦 FILE UPLOAD SETTINGS
# Folder name where PPTs will be stored
UPLOAD_PATH=uploads/

# 🎥 DEFAULT CONTENT FALLBACKS (Optional)
DEFAULT_PPT_URL=
DEFAULT_YOUTUBE_URL=